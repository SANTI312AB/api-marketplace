							{% if estado_pago =='APPROVED' %}
								<p>Aprobado</p>
							{% else %}
								<p>En espera de aprobación</p>
							{% endif %}
						</div>
						<small>* El plazo de entrega de los envíos sólo se considerará una vez que el vendedor acepte tu pedido</small>
					</div>
				</div>


