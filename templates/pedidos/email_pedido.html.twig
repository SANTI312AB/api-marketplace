														                ></div>
														              </div>
														                {#}
							{#}
														              <table style="margin-top: 20px; width: 100%">
														                <tr>
														                  <td style="text-align: center; width: 33%">
														                    <img src="../assets/bag.png" style="width: 20px" />
														                    <p>Realizado</p>
														                  </td>
														                  <td style="text-align: center; width: 33%">
														                    <img src="../assets/delivery.png" style="width: 24px" />
