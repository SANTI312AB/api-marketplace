							<div style="margin-top: 10px">
								<div style="
																				                    border: 1px solid #f3f4f6;
																				                    border-radius: 10px;
																				                    padding: 10px;
																				                    margin-top: 10px;
																				                  ">

									<table style="width: 100%">
										{% if detalle is not empty %}
											{% for detalleCarrito in detalle %}
												{% if detalleCarrito.tipo_producto == 'SERVICIO' %}
													<tr>
														<td style="vertical-align: middle">
															{% if detalleCarrito.imagenes is not empty %}
																<img src="{{ detalleCarrito.imagenes[0].url }}" style="width: 50px; height: 50px; border-radius: 10px"/>
