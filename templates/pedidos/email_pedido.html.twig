							{% endif %}


							<tr>
								<td style="text-align: left;">
									<p style="font-size: 20px;">Total a pagar</p>
								</td>
								<td style="text-align: right">
									<p style="font-size: 20px;">${{ total | number_format(2, '.', ',') }}</p>
								</td>
							</tr>
						</table>
					</div>
				</div>

				<!-- El siguiente bloque solo irá cuando un producto tiene el método de envío como entrega a domicilio -->

				{% set hay_entrega_domicilio = false %}
				{% for detalleCarrito in detalle %}
