														<td style="vertical-align: middle">
															{% if detalleCarrito.imagenes is not empty %}
																<img src="{{ detalleCarrito.imagenes[0].url }}" style="width: 50px; height: 50px; border-radius: 10px"/>
																{% else %}
																<!-- Aquí puedes poner una imagen predeterminada si no hay imágenes disponibles -->
															{% endif %}
														</td>
														<td style="width: 100%; vertical-align: top; padding-left: 10px;">
															<p style="font-weight: 600">{{ detalleCarrito.nombre_producto }}</p>
															<p>
																<span style="font-weight: 600">Cantidad:</span>
																{{ detalleCarrito.cantidad }}</p>
															<p style="font-weight: 600">Dirección:
																{{ detalleCarrito.direccion }}</p>
															<p style="font-weight: 600">Ciudad:{{ detalleCarrito.ciudad.nombre}}</p>

															{% if detalleCarrito.terminos is not empty %}
																<ul>
																	{% for termino in detalleCarrito.terminos %}
																		<li>{{ termino.nombre }}</li>
																	{% endfor %}
																</ul>
															{% endif %}
														</td>
														<td style="width: 100%; vertical-align: top; padding-left: 10px;">
															<p style="font-weight: 600">${{ detalleCarrito.precio | number_format(2, '.', ',') }}</p>
														</td>


													</tr>
												{% endif %}
											{% endfor %}
										{% else %}
											<tr>
												<td colspan="5">No hay elementos para retirar en tienda física en el carrito</td>
											</tr>
										{% endif %}

									</table>
								</div>


							</div>
						</div>

					{% endif %}

					{% set hay_entrega_domicilio = false %}
